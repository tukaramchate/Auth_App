SPRING_PROFILES_ACTIVE=dev
PORT=8083

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/auth_app
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Configuration
JWT_SECRET=generate_using_openssl_rand_base64_64
JWT_ISSUER=api.validation.com
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=86400
JWT_REFRESH_COOKIE_NAME=refreshToken
JWT_COOKIE_SECURE=false
JWT_COOKIE_HTTP_ONLY=true
JWT_COOKIE_SAME_SITE=lax
JWT_COOKIE_DOMAIN=localhost

# Frontend URLs
FRONTEND_URL=http://localhost:5173
FRONTEND_SUCCESS_URL=http://localhost:5173/oauth/success
FRONTEND_FAILURE_URL=http://localhost:5173/oauth/failure
FRONTEND_VERIFY_EMAIL_URL=http://localhost:5173/verify-email
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password

# Email Configuration
AUTH_EMAIL_FROM=no-reply@your-app.local
AUTH_EMAIL_VERIFICATION_ENABLED=true
AUTH_EMAIL_VERIFICATION_TTL_SECONDS=86400
AUTH_PASSWORD_RESET_ENABLED=true
AUTH_PASSWORD_RESET_TTL_SECONDS=1800

# Bootstrap Admin (disabled by default)
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN1_EMAIL=admin1@auth-app.local
BOOTSTRAP_ADMIN1_PASSWORD=
BOOTSTRAP_ADMIN1_NAME=Primary Admin
BOOTSTRAP_ADMIN2_EMAIL=admin2@auth-app.local
BOOTSTRAP_ADMIN2_PASSWORD=
BOOTSTRAP_ADMIN2_NAME=Secondary Admin

# Rate Limiting
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_LOGIN_LIMIT=5
APP_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
APP_RATE_LIMIT_REGISTER_LIMIT=10
APP_RATE_LIMIT_REGISTER_WINDOW_SECONDS=300
APP_RATE_LIMIT_FORGOT_PASSWORD_LIMIT=5
APP_RATE_LIMIT_FORGOT_PASSWORD_WINDOW_SECONDS=300
APP_RATE_LIMIT_RESET_PASSWORD_LIMIT=10
APP_RATE_LIMIT_RESET_PASSWORD_WINDOW_SECONDS=300
APP_RATE_LIMIT_REFRESH_LIMIT=30
APP_RATE_LIMIT_REFRESH_WINDOW_SECONDS=60

# SMTP Configuration (Gmail example)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# OAuth2 - Google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth2 - GitHub
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# OAuth2 - LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here